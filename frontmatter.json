{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.publicFolder": {
    "path": "src/assets",
    "relative": true
  },
  "frontMatter.content.pageFolders": [
    {
      "title": "posts",
      "path": "[[workspace]]/src/contents/posts",
      "previewPath": "/posts/"
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "posts",
      "slugTemplate": "{{slugifiedFileName}}",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": [
        {
          "name": "title",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "published",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true,
          "required": true
        },
        {
          "name": "draft",
          "type": "draft"
        },
        {
          "name": "description",
          "type": "string",
          "single": true
        },
        {
          "name": "cover",
          "type": "string",
          "single": true
        },
        {
          "name": "tags",
          "type": "tags"
        },
        {
          "name": "category",
          "type": "string",
          "single": true
        },
        {
          "name": "author",
          "type": "string",
          "single": true
        },
        {
          "name": "sourceLink",
          "type": "string",
          "single": true
        },
        {
          "name": "licenseName",
          "type": "string",
          "single": true
        },
        {
          "name": "licenseUrl",
          "type": "string",
          "single": true
        }
      ]
    }
  ],
  "frontMatter.git.enabled": true
}
