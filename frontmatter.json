{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.preview.pathName": "posts",
  "frontMatter.content.publicFolder": {
    "path": "src/assets",
    "relative": true
  },
  "frontMatter.content.pageFolders": [
    {
      "title": "posts",
      "path": "[[workspace]]/src/contents/posts"
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "posts",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": [
        {
          "name": "title",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "published",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true,
          "required": true
        },
        {
          "name": "draft",
          "type": "draft"
        },
        {
          "name": "description",
          "type": "string",
          "single": true
        },
        {
          "title": "content preview",
          "name": "preview",
          "type": "image",
          "isPreviewImage": true
        },
        {
          "name": "tags",
          "type": "tags"
        }
      ]
    },
    {
      "name": "specs",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": []
    }
  ],
  "frontMatter.git.enabled": true
}
